{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Zuljita/DungeonsOnAutomaticMonsters/schema/monster.schema.json",
  "title": "Dungeons on Automatic Public Monster Package",
  "type": "object",
  "required": ["manifest", "monsters"],
  "additionalProperties": false,
  "properties": {
    "manifest": {
      "type": "object",
      "required": ["id", "name", "version", "sourceBook", "licenseSummary", "packageUrl", "dataUrl", "sources"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "sourceBook": {
          "type": "object",
          "required": ["id", "name", "required", "derived"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "required": { "const": false },
            "derived": { "const": true }
          }
        },
        "licenseSummary": { "type": "string", "minLength": 1 },
        "packageUrl": { "type": ["string", "null"] },
        "dataUrl": { "type": ["string", "null"] },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "monsters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/monster" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["id", "name", "sourceSystem", "sourceLicense", "sourceUrl", "sourceCopyrightNotice"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "sourceSystem": { "enum": ["srd_3_5", "srd_5_1", "gcs_public", "doa_fixture"] },
        "sourceLicense": { "enum": ["ogl_1_0a", "cc_by_4_0", "gcs_public", "doa_authored"] },
        "sourceUrl": { "type": "string", "minLength": 1 },
        "sourceCopyrightNotice": { "type": "string", "minLength": 1 }
      }
    },
    "monster": {
      "type": "object",
      "required": ["id", "name", "tags", "treasure", "size", "grappling", "effectiveness", "encounter", "stats", "provenance", "sourceBook", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "pageRef": { "type": ["string", "null"] },
        "class": { "type": ["string", "null"] },
        "classTags": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "iq": { "type": ["number", "null"] },
        "appearance": { "type": ["string", "null"] },
        "lair": { "type": ["string", "null"] },
        "treasure": { "type": "object" },
        "size": { "type": "object" },
        "grappling": { "type": "object" },
        "effectiveness": { "type": "object", "required": ["combatEffectivenessRating", "threatTier"] },
        "encounter": { "type": "object" },
        "stats": { "type": "object", "required": ["attributes", "attacks", "traits", "skills", "notes"] },
        "provenance": { "$ref": "#/$defs/provenance" },
        "sourceBook": { "type": "string", "minLength": 1 },
        "sourceBooks": { "type": "array", "items": { "type": "string" } },
        "source": { "type": "object" }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "kind",
        "sourceSystem",
        "sourceLicense",
        "sourceMonsterId",
        "sourceName",
        "sourceUrl",
        "sourceCopyrightNotice",
        "conversionVersion",
        "conversionNotes",
        "manualReviewStatus",
        "packageSourceId",
        "license",
        "url",
        "originalId",
        "publicStats",
        "notes"
      ],
      "properties": {
        "kind": { "enum": ["workbook_metadata", "srd", "gcs_public", "doa_authored"] },
        "sourceSystem": { "enum": ["srd_3_5", "srd_5_1", "gcs_public", "doa_fixture"] },
        "sourceLicense": { "enum": ["ogl_1_0a", "cc_by_4_0", "gcs_public", "doa_authored"] },
        "sourceMonsterId": { "type": "string", "minLength": 1 },
        "sourceName": { "type": "string", "minLength": 1 },
        "sourceUrl": { "type": "string", "minLength": 1 },
        "sourceCopyrightNotice": { "type": "string", "minLength": 1 },
        "conversionVersion": { "type": "string", "minLength": 1 },
        "conversionNotes": { "type": "array", "items": { "type": "string" } },
        "manualReviewStatus": { "enum": ["draft", "review_required", "approved", "rejected"] },
        "packageSourceId": { "type": "string", "minLength": 1 },
        "license": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "originalId": { "type": ["string", "null"] },
        "publicStats": { "const": true },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
